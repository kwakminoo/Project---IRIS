# Ollama (기본 /api/chat 베이스)
OLLAMA_BASE_URL=http://localhost:11434
# LM Studio 등 OpenAI 호환 엔드포인트 베이스 (미설정 시 OLLAMA_BASE_URL과 동일하게 사용)
GEMMA_API_BASE_URL=http://localhost:11434
# Ollama 모델 태그 (예: ollama pull gemma4:e2b)
GEMMA_MODEL_NAME=gemma4:e2b
# 로컬 LLM 사용 여부 (false면 연결 시도 없이 안내 문구만)
USE_LOCAL_LLM=true
# ollama | openai_compatible (기본은 Ollama /api/chat)
GEMMA_BACKEND=ollama
USE_WHISPER=true
STT_MODEL=small

# TTS: edge(기본, 자연 음성) | pyttsx3(완전 로컬 폴백)
TTS_PROVIDER=edge
TTS_VOICE=ko-KR-SunHiNeural
TTS_RATE=-5%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%
# pyttsx3 폴백 시 속도 배율
TTS_SPEAKING_RATE=1.2
# 레거시: TTS_ENGINE=pyttsx3 만 설정 시 로컬 TTS만 사용 (TTS_PROVIDER 미설정일 때만 반영)

ENABLE_MONITORING=false
MONITOR_INTERVAL_SECONDS=3
STORE_SCREENSHOTS=false
STORE_RAW_OCR_TEXT=false

# OpenClaw — Iris 내부 Action Backend (사용자에게 이름 노출 불필요)
OPENCLAW_ENABLED=true
OPENCLAW_MODE=action_backend
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_SESSION_ID=iris-action
OPENCLAW_TIMEOUT_SECONDS=90

# TurnCoordinator 기본 경로 (Computer Use PAV). UI 텍스트/음성은 IRIS_MULTI_AGENT와 무관하게 Coordinator 경유
# 1=설정 플래그 on(기본), 0=레거시 플래그 off — Worker는 항상 TurnCoordinator 사용
IRIS_MULTI_AGENT=1
# (미사용) 레거시 fast path 플래그 — TurnCoordinator는 항상 Unified LLM Router 사용
IRIS_CHAT_FAST_PATH=false
# Playwright 웹 검색 headless (1=창 숨김 기본, 0=브라우저 표시)
IRIS_PLAYWRIGHT_HEADLESS=1
# 웹 검색: DuckDuckGo (ddgs 패키지, pip install ddgs — requirements.txt 포함)
# DuckDuckGo 실패 시 Playwright Google SERP 폴백 (1=켬, Google CAPTCHA 시 비권장)
IRIS_SEARCH_PLAYWRIGHT_FALLBACK=1
# TMDB 영화 — https://www.themoviedb.org/settings/api
# TMDB_API_KEY=
# Open-Meteo 날씨(키 불필요) — 기본 좌표(서울)
OPEN_METEO_DEFAULT_LAT=37.5665
OPEN_METEO_DEFAULT_LON=126.9780
# Frontier — 1회 LLM으로 선행 말(user_reply) + route envelope (실패 시 Unified Router 폴백)
IRIS_FRONTIER_ENABLED=true
IRIS_FRONTIER_MIN_CONFIDENCE=0.65
# Unified LLM Router (자연어 전체 → intent/lane/slots, 기본 on)
IRIS_UNIFIED_LLM_ROUTER=true
# LLM Intent Router (unified off일 때 lane/goal, 실패 시 규칙 폴백)
IRIS_LLM_INTENT_ROUTER=true
# Phase 3: 멀티턴 프리셋 catalog를 Gemma가 선택 (false면 regex match_* 만)
IRIS_PHASE3_MODE_PRESET_LLM=true

# Ollama (기본 /api/chat 베이스)
OLLAMA_BASE_URL=http://localhost:11434
# LM Studio 등 OpenAI 호환 엔드포인트 베이스 (미설정 시 OLLAMA_BASE_URL과 동일하게 사용)
GEMMA_API_BASE_URL=http://localhost:11434
# Ollama 모델 태그 (예: ollama pull gemma4:e2b)
GEMMA_MODEL_NAME=gemma4:e2b
# 설정창에 표시할 로컬 모델 목록
AI_MODEL_NAMES=gemma4:e2b
# 로컬 LLM 사용 여부 (false면 연결 시도 없이 안내 문구만)
USE_LOCAL_LLM=true
# ollama | openai_compatible (기본은 Ollama /api/chat)
# 비전(멀티모달 PNG)은 ollama만 지원 — openai_compatible(LM Studio 등)은 images 미지원
GEMMA_BACKEND=ollama
# 미디어 Ranker: 화면 캡처 PNG로 후보 순위 (메모리만, SQLite·디스크 저장 없음)
IRIS_MEDIA_RANKER_USE_SCREENSHOT=true
# 비전 전용 모델 태그 (비우면 GEMMA_MODEL_NAME 사용)
IRIS_MEDIA_RANKER_VISION_MODEL=gemma4:26b
# Ollama think: off(전체 끔) | default(실행·승인만) | on(전체 켬)
IRIS_THINKING_MODE=default
# Ollama 모델 메모리 유지 (예: 30m, 24h). 비우면 Ollama 기본값
OLLAMA_KEEP_ALIVE=30m
# DIALOGUE_CHAT 최근 대화 턴 수 (1턴=user+assistant)
DIALOGUE_HISTORY_TURNS=4
USE_WHISPER=true
# small | medium | large-v3 (한국어·호출어는 medium 이상 권장)
STT_MODEL=medium
# auto | cpu | cuda (auto는 cuBLAS DLL 사용 가능할 때만 CUDA, 없으면 CPU)
STT_DEVICE=auto
# auto | int8 | float16
STT_COMPUTE_TYPE=auto
# false 권장: 상시 마이크 VAD와 중복 방지
STT_VAD_FILTER=false
STT_BEAM_SIZE=5
# 비우면 VOICE_WAKE_WORDS 기반 짧은 힌트만 (설명 문장 없음)
STT_INITIAL_PROMPT=아이리스, iris, 이리스
STT_CONDITION_ON_PREVIOUS_TEXT=false
STT_NO_SPEECH_THRESHOLD=0.6
STT_MIN_AVG_LOGPROB=-1.0

# TTS: supertonic(Supertonic 3 로컬) | xtts | edge | pyttsx3
TTS_PROVIDER=supertonic
TTS_FALLBACK_PROVIDER=edge
TTS_VOICE=ko-KR-SunHiNeural
TTS_RATE=-5%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%
TTS_SPEAKING_RATE=1.2
TTS_VOICE_PRESET=iris_default
TTS_ENABLE_SPEECH_FORMATTER=true
TTS_ENABLE_VOICE_FX=true
TTS_MAX_SPOKEN_SENTENCES=3

# Supertonic 3 — https://huggingface.co/spaces/Supertone/supertonic-3
# 표시 이름(Lily) 또는 코드(F2). 음성 효과는 TTS_VOICE_PRESET·TTS_ENABLE_VOICE_FX로 유지
SUPERTONIC_VOICE=Lily
SUPERTONIC_LANGUAGE=ko
SUPERTONIC_TOTAL_STEPS=8

# XTTS-v2 (선택 — pip install -r requirements-tts.txt)
# 상업 배포 전 Coqui TTS / XTTS 라이선스 검토 필요
# XTTS_PROVIDER=xtts 시 사용
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=ko
# 본인 또는 사용 허가를 받은 참조 음성만 사용
XTTS_REFERENCE_WAV=assets/voices/iris_reference.wav
XTTS_DEVICE=auto
XTTS_SPEED=1.0
XTTS_ENABLE_CACHE=true
XTTS_CACHE_DIR=.cache/tts

# Barge-in (TTS 중 마이크로 끊기). Jarvis 모드 preset: true
BARGE_IN_ENABLED=true
BARGE_IN_GRACE_MS=450
BARGE_IN_RMS_MULTIPLIER=3.0
# TTS 종료 후 마이크 resume 지연 (스피커 잔향 방지)
VOICE_RESUME_DELAY_MS=250
VOICE_VAD_AUTO_CALIBRATE=true
VOICE_SPEECH_RMS_MULTIPLIER=2.5
VOICE_SILENCE_RMS_MULTIPLIER=1.3
TTS_PROCESSING_FILLER=false
# 상시 음성 대기 (Jarvis 스타일). 기본 켜짐
ALWAYS_LISTEN_ENABLED=true
# 특정 마이크 장치를 쓰려면 `python -m sounddevice`로 장치 번호를 확인한 뒤 설정
# ALWAYS_LISTEN_INPUT_DEVICE=1
# ALWAYS_LISTEN_SPEECH_RMS=0.018
# ALWAYS_LISTEN_SILENCE_MS=300
# 호출어가 있을 때만 음성 명령 처리
VOICE_REQUIRE_WAKE_WORD=true
VOICE_WAKE_WORDS=아이리스,iris,이리스
VOICE_FOLLOWUP_SECONDS=8
# 레거시: TTS_ENGINE=pyttsx3 만 설정 시 로컬 TTS만 사용 (TTS_PROVIDER 미설정일 때만 반영)

# 웹 URL 열기 기본 브라우저: chrome | edge | firefox | system
DEFAULT_WEB_BROWSER=chrome

# Chrome 확장 Iris Tab Monitor — chrome-extension/ 설치 후 팝업 포트와 동일
IRIS_EXTENSION_HOST=127.0.0.1
IRIS_EXTENSION_PORT=17777
IRIS_EXTENSION_TOKEN=

ENABLE_MONITORING=false
MONITOR_INTERVAL_SECONDS=3
STORE_SCREENSHOTS=false
STORE_RAW_OCR_TEXT=false

# Computer Use Phase B — UIA 우선 인식, VLM 보조 (Stub이면 VLM 스킵)
COMPUTER_USE_UIA_ENABLED=true
COMPUTER_USE_VLM_ENABLED=false
# verify/repair VLM (기본 on) | planner VLM (기본 off) — COMPUTER_USE_VLM_ENABLED=true 일 때만 적용
COMPUTER_USE_VLM_ON_VERIFY=true
COMPUTER_USE_VLM_ON_PLANNER=false
# 초기 Perceive 후 전체 plans[] 1회 작성 (false=레거시 1스텝 플래너)
COMPUTER_USE_FULL_PLAN_ENABLED=true
# 키보드·단축키·마우스 사용 전 충돌 안내 후 대기(초)
COMPUTER_USE_INPUT_NOTIFY_DELAY_SECONDS=2.0
# type_text: UIA·IME 사전 처리, typewrite 경로만 검증, 재시도 최대 1회
TYPE_INPUT_VERIFY_ENABLED=true
TYPE_INPUT_MAX_RETRIES=1
TYPE_INPUT_VISIBLE_INTERVAL=0.03
# CU 플래너 비전 — true 시 매 스텝 창 PNG 1장 + chat_with_images (메모리만)
# COMPUTER_USE_VISION_MODEL=gemma4:26b

# OpenClaw — Iris 내부 Action Backend (레거시 플래그; Tier4는 EXTERNAL_AGENT_* 사용)
OPENCLAW_ENABLED=true
OPENCLAW_MODE=action_backend
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_SESSION_ID=iris-action
OPENCLAW_TIMEOUT_SECONDS=90

# Tier 4 외부 에이전트 — 로컬 Computer Use 실패 시에만 (기본: 끔, none)
# EXTERNAL_AGENT_BACKEND=none | openclaw | hermes
EXTERNAL_AGENT_BACKEND=none
EXTERNAL_AGENT_FALLBACK_ENABLED=false
# 외부가 성공했다고 할 때 1회 perceive_desktop으로 현실 검증
EXTERNAL_AGENT_VERIFY_PERCEPTION=false
# Hermes CLI (선택)
HERMES_CLI_PATH=hermes

# 멀티-역할 파이프라인 (1=fast path + early ack TTS, 0=legacy)
IRIS_MULTI_AGENT=0

# Ollama (기본 /api/chat 베이스)
OLLAMA_BASE_URL=http://localhost:11434
# LM Studio 등 OpenAI 호환 엔드포인트 베이스 (미설정 시 OLLAMA_BASE_URL과 동일하게 사용)
GEMMA_API_BASE_URL=http://localhost:11434
# Ollama 모델 태그 (예: ollama pull gemma4:e2b)
GEMMA_MODEL_NAME=gemma4:e2b
# 설정창에 표시할 로컬 모델 목록
AI_MODEL_NAMES=gemma4:e2b
# 로컬 LLM 사용 여부 (false면 연결 시도 없이 안내 문구만)
USE_LOCAL_LLM=true
# ollama | openai_compatible (기본은 Ollama /api/chat)
GEMMA_BACKEND=ollama
USE_WHISPER=true
# small | medium | large-v3 (한국어·호출어는 medium 이상 권장)
STT_MODEL=medium
# auto | cpu | cuda
STT_DEVICE=auto
# auto | int8 | float16
STT_COMPUTE_TYPE=auto
# false 권장: 상시 마이크 VAD와 중복 방지
STT_VAD_FILTER=false
STT_BEAM_SIZE=5
# 비우면 VOICE_WAKE_WORDS 기반 자동 생성
# STT_INITIAL_PROMPT=아이리스, iris, 이리스. 한국어 음성 비서.

# TTS: xtts(고급 로컬, requirements-tts.txt) | edge(기본) | pyttsx3(완전 로컬)
TTS_PROVIDER=edge
TTS_FALLBACK_PROVIDER=edge
TTS_VOICE=ko-KR-SunHiNeural
TTS_RATE=-5%
TTS_PITCH=+0Hz
TTS_VOLUME=+0%
TTS_SPEAKING_RATE=1.2
TTS_VOICE_PRESET=iris_default
TTS_ENABLE_SPEECH_FORMATTER=true
TTS_ENABLE_VOICE_FX=true
TTS_MAX_SPOKEN_SENTENCES=3

# XTTS-v2 (선택 — pip install -r requirements-tts.txt)
# 상업 배포 전 Coqui TTS / XTTS 라이선스 검토 필요
# XTTS_PROVIDER=xtts 시 사용
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=ko
# 본인 또는 사용 허가를 받은 참조 음성만 사용
XTTS_REFERENCE_WAV=assets/voices/iris_reference.wav
XTTS_DEVICE=auto
XTTS_SPEED=1.0
XTTS_ENABLE_CACHE=true
XTTS_CACHE_DIR=.cache/tts

# Barge-in (TTS 중 마이크로 끊기). 기본 꺼짐
BARGE_IN_ENABLED=false
# 상시 음성 대기 (Jarvis 스타일). 기본 켜짐
ALWAYS_LISTEN_ENABLED=true
# 특정 마이크 장치를 쓰려면 `python -m sounddevice`로 장치 번호를 확인한 뒤 설정
# ALWAYS_LISTEN_INPUT_DEVICE=1
# ALWAYS_LISTEN_SPEECH_RMS=0.018
# ALWAYS_LISTEN_SILENCE_MS=300
# 호출어가 있을 때만 음성 명령 처리
VOICE_REQUIRE_WAKE_WORD=true
VOICE_WAKE_WORDS=아이리스,iris,이리스
VOICE_FOLLOWUP_SECONDS=8
# 레거시: TTS_ENGINE=pyttsx3 만 설정 시 로컬 TTS만 사용 (TTS_PROVIDER 미설정일 때만 반영)

ENABLE_MONITORING=false
MONITOR_INTERVAL_SECONDS=3
STORE_SCREENSHOTS=false
STORE_RAW_OCR_TEXT=false

# OpenClaw — Iris 내부 Action Backend (사용자에게 이름 노출 불필요)
OPENCLAW_ENABLED=true
OPENCLAW_MODE=action_backend
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_SESSION_ID=iris-action
OPENCLAW_TIMEOUT_SECONDS=90

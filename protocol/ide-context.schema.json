{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IrisIdeContext",
  "type": "object",
  "properties": {
    "type": { "const": "context.update" },
    "workspace_path": { "type": "string" },
    "active_file_uri": { "type": "string" },
    "active_file_language": { "type": "string" },
    "selected_text": { "type": "string" },
    "selection_range": {
      "type": "object",
      "properties": {
        "start": { "$ref": "#/definitions/position" },
        "end": { "$ref": "#/definitions/position" }
      }
    },
    "dirty_state": { "type": "boolean" }
  },
  "definitions": {
    "position": {
      "type": "object",
      "properties": {
        "line": { "type": "integer" },
        "character": { "type": "integer" }
      }
    }
  }
}

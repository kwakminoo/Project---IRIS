{
  "name": "@iris-ide/browser-app",
  "version": "0.1.0",
  "private": true,
  "theiaPluginsDir": "plugins",
  "theiaPlugins": [],
  "theia": {
    "target": "browser",
    "frontend": {
      "config": {
        "applicationName": "Iris IDE",
        "defaultTheme": "dark",
        "defaultIconTheme": "material-icon-theme"
      }
    },
    "backend": {
      "config": {
        "startupTimeout": -1
      }
    }
  },
  "dependencies": {
    "@iris-ide/iris-bridge": "0.1.0",
    "@iris-ide/iris-product": "0.1.0",
    "@theia/core": "1.55.0",
    "@theia/editor": "1.55.0",
    "@theia/filesystem": "1.55.0",
    "@theia/workspace": "1.55.0",
    "@theia/navigator": "1.55.0",
    "@theia/search-in-workspace": "1.55.0",
    "@theia/output": "1.55.0",
    "@theia/markers": "1.55.0",
    "@theia/preferences": "1.55.0",
    "@theia/scm": "1.55.0"
  },
  "devDependencies": {
    "@theia/cli": "1.55.0"
  },
  "scripts": {
    "build": "theia build --mode development",
    "start": "theia start --hostname=127.0.0.1 --port=3100",
    "watch": "theia build --watch --mode development"
  }
}

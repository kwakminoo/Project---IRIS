{
  "manifest_version": 3,
  "name": "Iris Tab Monitor",
  "version": "0.1.0",
  "description": "허용한 Chrome 탭의 요약만 Iris 로컬 서버로 전송합니다.",
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_title": "Iris 모니터링",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
